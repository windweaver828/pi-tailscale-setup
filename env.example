# pi-tailscale-role env/config
#
# Copy before editing:
#   cp .env.example .env
#
# This file may contain secrets. Do not commit .env.

PI_TS_HOSTNAME="tailsafe"
PI_TS_AUTH_KEY=""
PI_TS_EXTRA_UP_ARGS=""

PI_TS_ADVERTISE_EXIT_NODE="true"
PI_TS_ADVERTISE_DYNAMIC_LAN="true"
PI_TS_STATIC_ROUTES=""

PI_TS_ACCEPT_DNS="false"
PI_TS_ACCEPT_ROUTES="false"
PI_TS_APPLY_PERFORMANCE="true"

PI_TS_RESTART_ON_HEALTH_FAIL="true"
PI_TS_REBOOT_ON_REPEATED_FAILURE="false"
PI_TS_MAX_FAILURES_BEFORE_REBOOT="8"

# Optional email alert hook.
# Empty disables email alerts.
# If set, command should accept:
#   email.sh "Subject" "Message body"
PI_TS_EMAIL_COMMAND=""
PI_TS_EMAIL_AFTER_FAILURES="3"
PI_TS_EMAIL_COOLDOWN_SECONDS="3600"

# Optional reauth hook.
# Empty disables automatic reauth.
PI_TS_REAUTH_COMMAND=""
#PI_TS_REAUTH_COMMAND="/root/pi-tailscale-role/addons/auto-reauth/tailscale-nextcloud-reauth.sh"
PI_TS_REAUTH_AFTER_FAILURES="5"
PI_TS_REAUTH_COOLDOWN_SECONDS="900"

# Nextcloud reauth addon settings.
# Only used if PI_TS_REAUTH_COMMAND points to:
#   /root/pi-tailscale-role/addons/tailscale-nextcloud-reauth.sh
NC_USER="NEXTCLOUD_USER"
NC_APP_PASSWORD="NEXTCLOUD_APP_PASSWORD"
NC_WEBDAV_URL="https://nextcloud.example.com/remote.php/dav/files/$NC_USER/TailscaleRecovery/tailscale-authkey.txt"
